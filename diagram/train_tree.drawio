<mxfile host="app.diagrams.net" type="device"><diagram name="Train to crazy town" id="train-to-crazy-town"><mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="2400" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="band_0" value="STOP 0" style="rounded=1;html=1;dashed=1;dashPattern=6 4;strokeWidth=2;fillColor=none;verticalAlign=top;align=left;spacingLeft=12;spacingTop=6;fontStyle=1;fontSize=13;strokeColor=#6b7f96;fontColor=#6b7f96;" vertex="1" parent="1"><mxGeometry x="54" y="-30" width="230" height="144" as="geometry"/></mxCell><mxCell id="band_1" value="STOP 1" style="rounded=1;html=1;dashed=1;dashPattern=6 4;strokeWidth=2;fillColor=none;verticalAlign=top;align=left;spacingLeft=12;spacingTop=6;fontStyle=1;fontSize=13;strokeColor=#5a9367;fontColor=#5a9367;" vertex="1" parent="1"><mxGeometry x="-22" y="193" width="381" height="144" as="geometry"/></mxCell><mxCell id="band_2" value="STOP 2" style="rounded=1;html=1;dashed=1;dashPattern=6 4;strokeWidth=2;fillColor=none;verticalAlign=top;align=left;spacingLeft=12;spacingTop=6;fontStyle=1;fontSize=13;strokeColor=#b0a04a;fontColor=#b0a04a;" vertex="1" parent="1"><mxGeometry x="29" y="416" width="280" height="144" as="geometry"/></mxCell><mxCell id="band_3" value="STOP 3" style="rounded=1;html=1;dashed=1;dashPattern=6 4;strokeWidth=2;fillColor=none;verticalAlign=top;align=left;spacingLeft=12;spacingTop=6;fontStyle=1;fontSize=13;strokeColor=#c9932a;fontColor=#c9932a;" vertex="1" parent="1"><mxGeometry x="-7" y="639" width="352" height="144" as="geometry"/></mxCell><mxCell id="band_4" value="STOP 4" style="rounded=1;html=1;dashed=1;dashPattern=6 4;strokeWidth=2;fillColor=none;verticalAlign=top;align=left;spacingLeft=12;spacingTop=6;fontStyle=1;fontSize=13;strokeColor=#c96a4a;fontColor=#c96a4a;" vertex="1" parent="1"><mxGeometry x="50" y="862" width="237" height="144" as="geometry"/></mxCell><mxCell id="band_5" value="STOP 5" style="rounded=1;html=1;dashed=1;dashPattern=6 4;strokeWidth=2;fillColor=none;verticalAlign=top;align=left;spacingLeft=12;spacingTop=6;fontStyle=1;fontSize=13;strokeColor=#c0392b;fontColor=#c0392b;" vertex="1" parent="1"><mxGeometry x="14" y="1085" width="309" height="144" as="geometry"/></mxCell><mxCell id="e0" value="drop nationality discount" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#8a5fb0;" edge="1" parent="1" source="s0_parochial" target="s1_all_humans"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="169" y="127"/><mxPoint x="169" y="175"/></Array></mxGeometry></mxCell><mxCell id="e1" value="add animal welfare range" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#8a5fb0;" edge="1" parent="1" source="s1_all_humans" target="s2_animals"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="169" y="350"/><mxPoint x="169" y="398"/></Array></mxGeometry></mxCell><mxCell id="e2" value="add invertebrate sentience" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#8a5fb0;" edge="1" parent="1" source="s2_animals" target="s3_inverts"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="169" y="573"/><mxPoint x="169" y="621"/></Array></mxGeometry></mxCell><mxCell id="e3" value="stop discounting the future" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#8a5fb0;" edge="1" parent="1" source="s3_inverts" target="s4_future"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="169" y="796"/><mxPoint x="169" y="844"/></Array></mxGeometry></mxCell><mxCell id="e4" value="accept astronomical waste" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#8a5fb0;" edge="1" parent="1" source="s4_future" target="s5_astro"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="169" y="1019"/><mxPoint x="169" y="1067"/></Array></mxGeometry></mxCell><object label="Parochial&lt;br&gt;community + nation&lt;br&gt;→ Local Rotary Club&lt;br&gt;(common-sense default)" tooltip="&lt;b&gt;Only my community + nation count&lt;/b&gt;&lt;br&gt;&lt;br&gt;Least-crazy end of the line. Moral weight only on people near me; heavy pure-time discount; humans only; only near-certain, measurable effects count. Under these assumptions distant strangers, animals and the future are discounted to ~0, so the local/civic option wins. The pre-EA commonsense baseline; no single EA figure defends it." link="https://github.com/morganrivers/train_to_crazy_town/blob/refs/heads/claude/train-crazy-town-concept-j2y7pn/squiggle/nodes/s0_parochial.squiggle" id="s0_parochial"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#dfe7ef;strokeColor=#6b7f96;fontColor=#1b2733;" vertex="1" parent="1"><mxGeometry x="76" y="0" width="186" height="92" as="geometry"/></mxCell></object><object label="All present&lt;br&gt;humans&lt;br&gt;→ GiveWell top charity (AMF) / GiveDirectly&lt;br&gt;(Alexander Berger)" tooltip="&lt;b&gt;All present humans count equally&lt;/b&gt;&lt;br&gt;&lt;br&gt;Flip: drop the nationality discount (Peter Singer&#x27;s famine argument is the origin). A life saved abroad counts like a life saved at home, so cheap, measurable global-health and cash interventions dominate. Alexander Berger is the prominent exemplar of deliberately getting off the train here and staying with robust, evidence-backed global health &amp; wellbeing (GiveWell / Open Phil)." link="https://github.com/morganrivers/train_to_crazy_town/blob/refs/heads/claude/train-crazy-town-concept-j2y7pn/squiggle/nodes/s1_all_humans.squiggle" id="s1_all_humans"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#cfe6cf;strokeColor=#5a9367;fontColor=#1e3a24;" vertex="1" parent="1"><mxGeometry x="0" y="223" width="337" height="92" as="geometry"/></mxCell></object><object label="Farmed&lt;br&gt;animals count&lt;br&gt;→ The Humane League&lt;br&gt;(Peter Singer, Lewis Bollard)" tooltip="&lt;b&gt;Nonhuman animals count (welfare range)&lt;/b&gt;&lt;br&gt;&lt;br&gt;Flip: extend the moral circle to farmed vertebrates, weighted by a sentience-adjusted welfare range. Peter Singer (Animal Liberation) is the canonical articulator; Lewis Bollard leads Open Phil&#x27;s farm-animal-welfare work. Corporate welfare campaigns avert enormous suffering per dollar and overtake human global health under most welfare-range estimates." link="https://github.com/morganrivers/train_to_crazy_town/blob/refs/heads/claude/train-crazy-town-concept-j2y7pn/squiggle/nodes/s2_animals.squiggle" id="s2_animals"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#e6e2c0;strokeColor=#b0a04a;fontColor=#3a3410;" vertex="1" parent="1"><mxGeometry x="51" y="446" width="236" height="92" as="geometry"/></mxCell></object><object label="Invertebrates&lt;br&gt;count&lt;br&gt;→ Shrimp Welfare Project  (UNSTABLE)  ▼&lt;br&gt;(Brian Tomasik)" tooltip="&lt;b&gt;Invertebrates count (neuron-count exponent)&lt;/b&gt;&lt;br&gt;&lt;br&gt;Flip: count invertebrates, with welfare range ~ (neuron count)^exponent. Brian Tomasik is the prominent voice on insect / invertebrate suffering. First UNSTABLE stop: sweeping the exponent from 0 to 2 swings shrimp welfare range across ~12 orders of magnitude and the ranking flips. Marked subgraph: clicking here should open the soil-animal sub-tree (macroarthropods / microarthropods / nematodes) - TBD." link="https://github.com/morganrivers/train_to_crazy_town/blob/refs/heads/claude/train-crazy-town-concept-j2y7pn/squiggle/nodes/s3_inverts.squiggle" id="s3_inverts"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#f6e0c0;strokeColor=#c9932a;fontColor=#5a3f10;" vertex="1" parent="1"><mxGeometry x="15" y="669" width="308" height="92" as="geometry"/></mxCell></object><object label="Future&lt;br&gt;people count&lt;br&gt;→ ALLFED&lt;br&gt;(Ajeya Cotra, Toby Ord)" tooltip="&lt;b&gt;Future people count (low/zero time discount)&lt;/b&gt;&lt;br&gt;&lt;br&gt;Flip: stop discounting future lives. Toby Ord (The Precipice) and Will MacAskill (What We Owe The Future) are the prominent longtermists; Ajeya Cotra coined the &#x27;train to crazy town&#x27; metaphor and rides roughly to here via worldview diversification, taking the future seriously while flagging where it gets uncomfortable. Reducing global-catastrophic risk (e.g. ALLFED&#x27;s civilisational-resilience work) starts to dominate present-focused giving." link="https://github.com/morganrivers/train_to_crazy_town/blob/refs/heads/claude/train-crazy-town-concept-j2y7pn/squiggle/nodes/s4_future.squiggle" id="s4_future"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#f2ccc0;strokeColor=#c96a4a;fontColor=#5a2410;" vertex="1" parent="1"><mxGeometry x="72" y="892" width="193" height="92" as="geometry"/></mxCell></object><object label="Astronomical&lt;br&gt;stakes&lt;br&gt;→ AI safety (x-risk)&lt;br&gt;(Nick Bostrom, Eliezer Yudkowsky)" tooltip="&lt;b&gt;Astronomical waste + tiny-probability bets count&lt;/b&gt;&lt;br&gt;&lt;br&gt;Last marked stop on this spine: accept Nick Bostrom&#x27;s astronomical-waste argument and take small-probability / huge-payoff bets at face value; Eliezer Yudkowsky pushes AI-risk reasoning to its stark conclusions. Existential-risk reduction dominates everything. This is the far end Cotra&#x27;s near-termist deliberately gets off before; ride further and you reach fanaticism / Pascal&#x27;s-mugging territory." link="https://github.com/morganrivers/train_to_crazy_town/blob/refs/heads/claude/train-crazy-town-concept-j2y7pn/squiggle/nodes/s5_astro.squiggle" id="s5_astro"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#eeb3b3;strokeColor=#c0392b;fontColor=#5a1410;" vertex="1" parent="1"><mxGeometry x="36" y="1115" width="265" height="92" as="geometry"/></mxCell></object></root></mxGraphModel></diagram></mxfile>