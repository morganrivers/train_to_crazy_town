><mxPoint x="409" y="340"/><mxPoint x="409" y="340"/><mxPoint x="409" y="613"/><mxPoint x="409" y="613"/><mxPoint x="372" y="682"/><mxPoint x="372" y="682"/><mxPoint x="372" y="682"/><mxPoint x="329" y="748"/></Array></mxGeometry></mxCell><mxCell id="e3" value="adopt RP welfare ranges + invertebrates" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#8a5fb0;" edge="1" parent="1" source="w1_2" target="w1_2_7"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="450" y="220"/><mxPoint x="483" y="340"/><mxPoint x="483" y="340"/><mxPoint x="483" y="340"/><mxPoint x="483" y="340"/><mxPoint x="483" y="884"/><mxPoint x="483" y="884"/><mxPoint x="446" y="953"/><mxPoint x="446" y="953"/><mxPoint x="446" y="953"/><mxPoint x="399" y="1019"/></Array></mxGeometry></mxCell><mxCell id="e4" value="weight suffering over happiness" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#8a5fb0;" edge="1" parent="1" source="w1_2" target="w1_2_8"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="491" y="220"/><mxPoint x="557" y="340"/><mxPoint x="557" y="340"/><mxPoint x="557" y="340"/><mxPoint x="557" y="340"/><mxPoint x="557" y="1155"/><mxPoint x="557" y="1155"/><mxPoint x="520" y="1224"/><mxPoint x="520" y="1224"/><mxPoint x="520" y="1224"/><mxPoint x="448" y="1292"/></Array></mxGeometry></mxCell><mxCell id="e5" value="charge humans for the meat they eat" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#8a5fb0;" edge="1" parent="1" source="w1_2" target="w1_2_9"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="532" y="220"/><mxPoint x="631" y="340"/><mxPoint x="631" y="340"/><mxPoint x="631" y="340"/><mxPoint x="631" y="340"/><mxPoint x="631" y="1426"/><mxPoint x="631" y="1426"/><mxPoint x="631" y="1536"/></Array></mxGeometry></mxCell><mxCell id="e6" value="charge humans for the meat they eat" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#8a5fb0;" edge="1" parent="1" source="w1_2_8" target="w1_2_8_9"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="284" y="1532"/><mxPoint x="275" y="1578"/></Array></mxGeometry></mxCell><object label="Animals count&lt;br&gt;(neuron-weighted)&lt;br&gt;[1+2]&lt;br&gt;→ The Humane League&lt;br&gt;   24 lives-eq/$1k · 100% best&lt;br&gt;   runner-up GiveWell top charity (AMF) · 0%&lt;br&gt;(Peter Singer, Lewis Bollard)" tooltip="&lt;b&gt;parochial + far_away_humans + animals_somewhat&lt;/b&gt;&lt;br&gt;&lt;br&gt;Farmed vertebrates enter the circle, weighted by a sentience-adjusted welfare range (neuron-count exponent). Corporate welfare campaigns avert enormous suffering per dollar and overtake human global health under most welfare-range estimates. An animals person won&#x27;t think only people in their community matter, so this assumption requires far_away_humans. || Chain: 0 parochial → 1 far_away_humans → 2 animals_somewhat" link="https://www.squiggle-language.com/playground#code=eJylWP1vm0gQ%2FVdG0enOrhwC%2BAPbvZzkNk5bXdJWSaqqqqtkDWuzF75udzH1pfnfbxaMWSdYQfIvLYHlvTdvhp1ZPxx5dEHSQL6NPXo0Pjo5gdPTU7jhhEUgY3A5%2BW%2BNF1kEs9Q2rR5kMQ%2B8FaMZZNatDS0h4wTstnptFuHrEyHSMJEsjsD1EWUMJiSEx67PSKBArJENFiwIvyUZWd%2F6aUgiUT6wgUQsJIG4FXFIM5%2FIHHRKXB9IhcwEEPi8lj5eL1hAAdVWj8UJSHwTiOeJDnCKIbKICoh5DsbpMQoiIZWUM4H3pU8LrX8IWKSRm2O8BjcOk1iwaFktwHcjjyIi3mIiRxOSRB4J4ohCiB4GBtxtLZqu7pRU9Tr9mVBX4osrEqQU4kWOULlp5GBvqJAwT9eQKhr1oqB6YGO4Qaz3yjIKF5QsU1q8%2BG76cXo1uZmewXwNSxpRTiQ1knWZNeoxuePQK3zYgSiWhQ5lIiLlWGeMo1Sgi4X6Dx2myv2YL9GehGN2%2BBrmSLFgLsPrDryZnn%2B6mmL4nAQ5QkbZ0pfoXAc5MVMh5jKSxyGRro8WBPEyijlmGa6%2FXF5Orr4VdmDGChI05Z56OdI8ltSFVkhJBJOPZ%2BgeZyRylZ%2FElW0j92ORBgEWlCtjfjxfHxdXgAayFcnLpTChkMakXwRULMtjilc0ylExlSDilOPlxriArbBC1MeARAGLSmHi35QtlwE9yRWKkz%2BZ95dR3iwqoYNQgLaj