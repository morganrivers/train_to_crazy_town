ry relative="1" as="geometry"><Array as="points"><mxPoint x="893" y="178"/><mxPoint x="855" y="224"/></Array></mxGeometry></mxCell><mxCell id="e1" value="give merely-possible future people no weight" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#8a5fb0;" edge="1" parent="1" source="w1_2_5_6_7_8_15" target="w1_2_5_6_7_8_15_17"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1005" y="241"/><mxPoint x="1032" y="426"/></Array></mxGeometry></mxCell><mxCell id="e2" value="give merely-possible future people no weight" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#8a5fb0;" edge="1" parent="1" source="w1_2_5_6_7_8_15_16" target="w1_2_5_6_7_8_15_16_17"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="708" y="448"/><mxPoint x="686" y="494"/></Array></mxGeometry></mxCell><mxCell id="e3" value="count the ~10^19 soil invertebrates" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#8a5fb0;" edge="1" parent="1" source="w1_2_5_6_7_8_15" target="w1_2_5_6_7_8_15_18"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1213" y="220"/><mxPoint x="1401" y="340"/><mxPoint x="1401" y="340"/><mxPoint x="1401" y="340"/><mxPoint x="1401" y="340"/><mxPoint x="1401" y="613"/><mxPoint x="1401" y="613"/><mxPoint x="1438" y="724"/></Array></mxGeometry></mxCell><mxCell id="e4" value="count the ~10^19 soil invertebrates" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#8a5fb0;" edge="1" parent="1" source="w1_2_5_6_7_8_15_16" target="w1_2_5_6_7_8_15_16_18"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="540" y="469"/><mxPoint x="413" y="542"/><mxPoint x="413" y="542"/><mxPoint x="413" y="542"/><mxPoint x="310" y="704"/></Array></mxGeometry></mxCell><mxCell id="e5" value="count the ~10^19 soil invertebrates" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#8a5fb0;" edge="1" parent="1" source="w1_2_5_6_7_8_15_17" target="w1_2_5_6_7_8_15_17_18"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1059" y="719"/><mxPoint x="1059" y="765"/></Array></mxGeometry></mxCell><mxCell id="e6" value="count the ~10^19 soil invertebrates" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#8a5fb0;" edge="1" parent="1" source="w1_2_5_6_7_8_15_16_17" target="w1_2_5_6_7_8_15_16_17_18"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="629" y="719"/><mxPoint x="629" y="765"/></Array></mxGeometry></mxCell><object label="Early space expansion&lt;br&gt;re-arms the hazard&lt;br&gt;[1+2+5+6+7+8+15]&lt;br&gt;→ Shrimp Welfare Project&lt;br&gt;   66k lives-eq/$1k · 68% best&lt;br&gt;   runner-up Wild insects (humane pesticides) · 28%&lt;br&gt;(Daniel Deudney, Kelly &amp; Zach Weinersmith)" tooltip="&lt;b&gt;parochial + far_away_humans + animals_somewhat + future_humans_matter_with_discounting + no_discounting_future_humans + animals_matter_a_lot + suffering_focused + space_expansion_backfires&lt;/b&gt;&lt;br&gt;&lt;br&gt;The sweet-spot view: the capability that settles planets also moves asteroids and exports nationalism off-world (Deudney, Dark Skies), and genuinely decorrelated self-sufficient settlements are far further away than boosterism assumes (Weinersmiths, A City on Mars) — so below a large number of independent settlements, expansion ADDS anthropogenic risk, and accelerating it before geopolitics matures is net-negative. The perils window stays open far longer, the expected future shrinks, and x-risk work keeps its urgency but loses most of its astronomical multiplier. Mutually exclusive with the time-of-perils-exit reading. || Chain: 0 parochial → 1 far_away_humans → 2 animals_somewhat → 5 future_humans_matter_with_discounting → 6 no_discounting_future_humans → 7 animals_matter_a_lot → 8 suffering_focused → 15 space_expansion_backfires" link="https://www.squiggle-language.com/playground#code=eJy1WW1v2zgS%2FiuD4PbO7vlFkt%2BTywFp4%2BwWm3SLJL1i0RQuLdEWL5KoI6k43m72t%2B%2BQlGw5VlD1jP1SuBLnmWdeNcN8PQrogmSResMDenR81O3C6ekp3ArCElAcfEF%2BW%2BOPVQJ3mee4fVhxEQUPjK5g5c682WA2nI1m45k7gIZUPAV30NQQdwlCnUmZxaliPAE%2FRMRjcCAlgvshI5EGdCceuLAgYkZWZD0Ls5gksnjhAUlYTCI5kzymq5Co4s0AFpnKBM0FZjFRiorZiqlwFjDp8yxRLFkWx4eQ8PLz2Y50cWq0UZfDkVnENyrHILPFggojzv1M0mBjwABkSnw6o48p4qG1sznx7xdMUGncMCV%2BCGTrCyaBwPu1CvH3gkUU0Nfb17ILSttKgkC2QFAMEEuoBC4MmKBtdCGJKVJkEp%2BrkFrv%2FkOiWxLfYJyAz%2BOUS%2B2FzQGUTQKKiPiIWWpSkSQgEU8oxJgBUQe%2BbAI8ffiiqWpxtIz6CgUfSJRR4AuDsM2FjgF7TaWCebaGTKvRgpKWDTuGm1CwOIWPNMKYU3gv%2BH8R10r%2FOH03vT67nZ7DfA1LmlBBFO2k6yLxaMDUjpte4csWhlZZMtqTiGSwPiQ%2BFUqbHHOBqbbxmLRnrTtImkaMyg7crONOxJcJFxj%2Fxtd00IJ0MnhqGiwTrYnzA7x5e2JOzqki9mkq%2BJzMWcQUEplzbXagq%2BaT0wL3cwcuiK846kRbLRQeSHUMEtUCyYHqxOBiiZGbflqdn13%2B2v3bZ5jTiK%2BwKLSsiTB9xN%2FRGsURG71qsFB3kPnKxgKjRzH10PxFxDOUCjHw53nGw%2Bm%2BgViJHWdszNQ%2Fx09NAJNciIk2rChbhoiNdSsoMbUUord0Hkpo3PKYSHZ%2FAv9Bg%2FQ7z%2FEcdNamQt4LhtTVulqz23FzxcPOIFdMH5UgJbXkAeOnodFmmmAabbBfVm%2BrumS1a6BTfNhWLKbwT%2FCJIlIJnqLHdJEnGTEVqQuRiLZFyJO8cU1iSdfdG0ybBP5wfuiuBTxIeMdFEJJMwh9uZ6AfnqCiU8xDKFqMdoVuCK%2FzLnCF%2FZXpVBMvhsLbhGKYe0RhpWheO%2BWXE1yFumtQIjApNk1HdwYiYluwIfmNiAAa5zQLErrGBAsyErUzU5BoEGdBl4s5U1gcLFkI7RXMJgQ%2FwerEOAsZYzeVmkFoslFgpi1QBwpILN%2B2DgjzGU18TEzZzAvvHM3FpKQYLN8EspTiKVpExBrzO6FaFH%2B34PX04pfrqS1Tg2BzAMPaQqZYYzH2%2FkS1sSf7IXpg4zq4%2BXB1dXb9qy0A7JdWCbakexoYpDlX1IeGrgw4e3eOYRWMYGOw9dTswC06apFFUV5r7fm6bX8Bti%2F2YFPDdh9LDT1iDbLHjE38gSYGFRsp1nQm8GfesSL2gNXLbAwjlhTE5P8ytlxGtGsYyu6%2FWPDvTvHQ9mHTHrDfYZvRfQ8NR5hf3k0hjYjVlX8MSKDbJcVyWW%2FbMX42COrULRhtZwnqNgjYPuxJ2%2BsxTXmW%2Fsy0Z5NzEq3fU%2FFBBtVJOuwMvcmkNx5Mxq7XGzkubTuDTdY6jjuajEe9vuuMRgPXG7n9PI%2BfxQ%2Fbt0mCvG1pArN7y2AnYH9%