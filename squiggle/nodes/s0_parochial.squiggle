// Stop 0 - Parochial (community + nation only). Commonsense pre-EA baseline.
// Only local humans have moral weight; animals, distant strangers and the
// future are outside the circle. Expected winner: Local Rotary Club.
import "hub:morganrivers/base_model" as base

assumptions = {
  w_local: 1, w_global: 0, w_farmed: 0, w_invert: 0, w_future: 0, w_xrisk: 0,
  neuron_exponent: 0,
  accept_tiny_prob: false,
}

ranking = base.evaluate(assumptions)
