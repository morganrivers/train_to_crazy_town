// === Train to crazy town — worldview w1_3_4_10 (stop 10) ===
// Assumption chain: 0 parochial → 1 far_away_humans → 3 future_humans_matter_with_discounting → 4 no_discounting_future_humans → 10 person_affecting_view
// Each assumption is a Python file in assumptions/ that adds, redefines or
// re-parameterises the chain's functions; composing the chain rendered this
// standalone model. `worldviewEv` is the expected value of this worldview.
// Best buy under these assumptions: AI safety (Redwood Research).
// GENERATED by generate.py — edit assumptions/*.py, not this file.

// Direct effect on each org's primary beneficiary, BEFORE moral
// weighting. `lo to hi` is a lognormal 90% CI (order-of-magnitude BOTEC).
soupKitchenDalyPerUsd = {
  peopleHelpedPerUsd = 0.05 to 0.5
  wellbeingGainDaly = 0.001 to 0.01
  counterfactualBankValue = 0.3
  peopleHelpedPerUsd * wellbeingGainDaly * (1 - counterfactualBankValue)
}
gdDalyPerUsd = 0.0004 to 0.002
amfDalyPerUsd = 0.0035 to 0.021
aimDalyPerUsd = 0.001 to 0.025
thlDalyPerUsd = 1.2 to 47
swpDalyPerUsd = 1200 to 74000
wildbugsDalyPerUsd = 1600 to 82000
allfedDalyPerUsd = {
  pAgriculturalCatastrophePerCentury = 0.003 to 0.05
  livesSavedPerDollarIfCatastrophe = 0.02 to 2
  dalyPerLife = 30
  pCivilizationEndingGivenCatastrophe = 0.005 to 0.1
  riskShareRemovedPerDollar = 1e-10 to 1e-09
  futureDalysAtStake = 100000000000 to 10000000000000000
  pAgriculturalCatastrophePerCentury * livesSavedPerDollarIfCatastrophe * dalyPerLife + pAgriculturalCatastrophePerCentury * pCivilizationEndingGivenCatastrophe * riskShareRemovedPerDollar * futureDalysAtStake
}
redwoodDalyPerUsd = {
  xRiskReducedPerDollar = 1e-13 to 1e-12
  futureDalysAtStake = 100000000000 to 10000000000000000
  xRiskReducedPerDollar * futureDalysAtStake
}

// E[wDALY averted per $]: each org's direct effect times the moral
// coefficient this worldview's assumption chain puts on it.
scored = [
  { name: "Local soup kitchen", wdalyPerUsd: mean(soupKitchenDalyPerUsd) * 1 },
  { name: "GiveDirectly", wdalyPerUsd: mean(gdDalyPerUsd) * 1 },
  { name: "GiveWell top charity (AMF)", wdalyPerUsd: mean(amfDalyPerUsd) * 1 },
  { name: "AIM / Charity Entrepreneurship", wdalyPerUsd: mean(aimDalyPerUsd) * 1 },
  { name: "The Humane League", wdalyPerUsd: mean(thlDalyPerUsd) * 0 },
  { name: "Shrimp Welfare Project", wdalyPerUsd: mean(swpDalyPerUsd) * 0 },
  { name: "Wild insects (humane pesticides)", wdalyPerUsd: mean(wildbugsDalyPerUsd) * 0 },
  { name: "ALLFED", wdalyPerUsd: mean(allfedDalyPerUsd) * 3e-05 },
  { name: "AI safety (Redwood Research)", wdalyPerUsd: mean(redwoodDalyPerUsd) * 3e-05 },
]

ranking = List.reverse(List.sortBy(scored, {|x| x.wdalyPerUsd}))
best = ranking[0]

// The expected value of THIS worldview: what its best buy achieves.
worldviewEv = best.wdalyPerUsd
